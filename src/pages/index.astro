---
import Layout from '../layouts/Layout.astro';
import { chapters, getChaptersByCategory } from '../config/chapters';
const categories = getChaptersByCategory();
const base = import.meta.env.BASE_URL;
---

<Layout>
  <div class="lang-toggle-wrapper">
    <button class="lang-toggle" id="lang-toggle" aria-label="Switch language">
      <span class="lang-toggle__option" data-lang-opt="zh">ZH</span>
      <span class="lang-toggle__sep">/</span>
      <span class="lang-toggle__option" data-lang-opt="en">EN</span>
    </button>
  </div>

  <main class="home">
    <section class="hero">
      <div class="hero-terminal">
        <div class="hero-terminal__bar">
          <span class="hero-terminal__dot" style="background:#ff5f56"></span>
          <span class="hero-terminal__dot" style="background:#ffbd2e"></span>
          <span class="hero-terminal__dot" style="background:#27c93f"></span>
        </div>
        <div class="hero-terminal__body">
          <span class="hero-terminal__prompt">$</span>
          <span class="hero-terminal__cmd">claude</span>
          <span class="hero-terminal__cursor"></span>
        </div>
      </div>

      <h1 class="hero-title">Claude 101</h1>

      <p class="hero-subtitle">
        <span data-zh="以 AI 的第一人称视角" data-en="From AI's first-person perspective">以 AI 的第一人称视角</span><br />
        <span data-zh="交互式理解 Claude Code 的工作原理" data-en="Interactively understand how Claude Code works">交互式理解 Claude Code 的工作原理</span>
      </p>

      <a href={`${base}/chapters/prompt`} class="hero-cta">
        <span data-zh="开始旅程 →" data-en="Start the Journey →">开始旅程 →</span>
      </a>
    </section>

    <section class="chapter-journey">
      {categories.map((cat) => (
        <div class="journey-category">
          <div class="journey-category__header">
            <span class="journey-category__dot" style={`background: ${cat.color}`}></span>
            <span class="journey-category__name" data-zh={cat.name} data-en={cat.nameEn}>{cat.name}</span>
          </div>
          <div class="journey-category__chapters">
            {cat.chapters.map((chapter) => (
              <a href={`${base}/chapters/${chapter.slug}`} class="journey-card">
                <span class="journey-card__num" style={`color: ${cat.color}`}>{String(chapter.id).padStart(2, '0')}</span>
                <div class="journey-card__content">
                  <span class="journey-card__title">{chapter.title}</span>
                  <span class="journey-card__sub" data-zh={chapter.subtitle} data-en={chapter.subtitleEn}>{chapter.subtitle}</span>
                </div>
                <span class="journey-card__icon">{chapter.icon}</span>
              </a>
            ))}
          </div>
        </div>
      ))}
    </section>

    <footer class="home-footer">
      <span data-zh="由" data-en="Made by">由</span>
      <a href="https://ursb.me" target="_blank" rel="noopener noreferrer" class="footer-link">Airing</a>
      <span data-zh="创作" data-en="">创作</span>
      <span class="footer-sep">·</span>
      <a href="https://github.com/airingursb/claude-101" target="_blank" rel="noopener noreferrer" class="footer-link">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
          <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z" />
        </svg>
        GitHub
      </a>
    </footer>
  </main>
</Layout>

<script>
  function getCurrentLang(): string {
    return localStorage.getItem('claude101-lang') || 'zh';
  }

  function applyLang(lang: string) {
    document.documentElement.lang = lang === 'en' ? 'en' : 'zh-CN';
    document.documentElement.dataset.lang = lang;

    document.querySelectorAll('[data-lang-opt]').forEach((el) => {
      const opt = (el as HTMLElement).dataset.langOpt;
      el.classList.toggle('lang-toggle__option--active', opt === lang);
    });

    document.querySelectorAll('[data-zh][data-en]').forEach((el) => {
      const htmlEl = el as HTMLElement;
      htmlEl.textContent = lang === 'en' ? htmlEl.dataset.en! : htmlEl.dataset.zh!;
    });
  }

  function toggleLang() {
    const current = getCurrentLang();
    const next = current === 'zh' ? 'en' : 'zh';
    localStorage.setItem('claude101-lang', next);
    applyLang(next);
    window.dispatchEvent(new CustomEvent('claude101-lang-change', { detail: next }));
  }

  applyLang(getCurrentLang());
  document.getElementById('lang-toggle')?.addEventListener('click', toggleLang);

  window.addEventListener('claude101-lang-change', (e: Event) => {
    applyLang((e as CustomEvent).detail);
  });
</script>

<style>
  .home {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* ── Hero ── */
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 100px 20px 64px;
    max-width: 600px;
  }

  .hero-terminal {
    background: #1a1a2e;
    border-radius: 10px;
    overflow: hidden;
    width: 280px;
    margin-bottom: 36px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
  }

  .hero-terminal__bar {
    display: flex;
    gap: 6px;
    padding: 10px 14px;
    background: #16162a;
  }

  .hero-terminal__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .hero-terminal__body {
    padding: 16px 18px 20px;
    font-family: var(--font-mono);
    font-size: 15px;
    color: #e0e0e0;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .hero-terminal__prompt {
    color: var(--color-success);
  }

  .hero-terminal__cmd {
    color: #c084fc;
  }

  .hero-terminal__cursor {
    display: inline-block;
    width: 8px;
    height: 18px;
    background: #c084fc;
    border-radius: 1px;
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    50% { opacity: 0; }
  }

  .hero-title {
    font-size: 56px;
    font-weight: 800;
    line-height: 1.1;
    margin: 0 0 16px;
    color: var(--color-text);
    font-family: var(--font-mono);
    letter-spacing: -1px;
  }

  .hero-subtitle {
    font-size: 18px;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin: 0 0 32px;
    font-family: var(--font-hand);
    font-size: 22px;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    padding: 14px 36px;
    background: var(--color-accent);
    color: white;
    border-radius: 100px;
    font-family: var(--font-hand);
    font-size: 20px;
    font-weight: 600;
    text-decoration: none;
    transition: transform 0.15s, box-shadow 0.15s;
    box-shadow: 0 4px 16px rgba(124, 58, 237, 0.3);
  }

  .hero-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 24px rgba(124, 58, 237, 0.4);
  }

  /* ── Chapter Journey ── */
  .chapter-journey {
    width: 100%;
    max-width: 640px;
    padding: 0 20px 40px;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .journey-category__header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
    padding-left: 4px;
  }

  .journey-category__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .journey-category__name {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
  }

  .journey-category__chapters {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .journey-card {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 14px 16px;
    border-radius: 10px;
    text-decoration: none;
    transition: background 0.15s;
    cursor: pointer;
  }

  .journey-card:hover {
    background: rgba(124, 58, 237, 0.04);
  }

  .journey-card__num {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 700;
    flex-shrink: 0;
    width: 24px;
    text-align: right;
  }

  .journey-card__content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .journey-card__title {
    font-size: 16px;
    font-weight: 600;
    color: var(--color-text);
  }

  .journey-card__sub {
    font-size: 14px;
    color: var(--color-text-muted);
    font-family: var(--font-hand);
    font-size: 15px;
  }

  .journey-card__icon {
    font-size: 20px;
    flex-shrink: 0;
    opacity: 0.7;
  }

  /* ── Footer ── */
  .home-footer {
    padding: 32px 20px 40px;
    font-size: 14px;
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
  }

  .footer-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-link:hover {
    color: var(--color-accent);
  }

  .footer-sep {
    margin: 0 4px;
    opacity: 0.4;
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .hero {
      padding: 72px 20px 48px;
    }

    .hero-title {
      font-size: 40px;
    }

    .hero-terminal {
      width: 240px;
    }

    .chapter-journey {
      padding: 0 12px 32px;
    }
  }
</style>
